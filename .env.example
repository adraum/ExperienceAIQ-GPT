# Azure OpenAI configuration (server-side only — never expose these to the browser).
# These variables are read by the Vercel serverless function at /api/ai.ts.
# On Vercel: configure them under Project Settings → Environment Variables.
AZURE_OPENAI_ENDPOINT="https://franceki.openai.azure.com/"
AZURE_OPENAI_API_KEY="your-azure-openai-api-key"
AZURE_OPENAI_DEPLOYMENT="gpt-5-nano"
AZURE_OPENAI_API_VERSION="2024-12-01-preview"
